graph TD
    subgraph ALAYA_SYSTEMD ["Alaya (systemd)"]
        QWEN["local-llm\nQwen2.5-Coder-14B\nport 8001"]
        QUEUE["local-queue\nTask queue daemon"]
        ALAYABOT["alaya-bot\n@Alaya13jbot"]
        GROKBOT["grok-bot\n@Alaya_grokbot"]
        DASH["dashboard\nCommand Center"]
        MINIAPP["miniapp\nZangetsu Mini App"]
        AGENT["alaya-agent\n[STOPPED]"]
    end

    subgraph ALAYA_DOCKER_DEPLOY ["Docker: deploy project"]
        TRADER["deploy-trader\npaper_trader.py\nBTC/USDT 1m"]
        MLCORE["deploy-ml_core\nfeature tournament\nregime detection"]
        PG[("deploy-postgres\nPostgreSQL 15\npgvector")]
        REDIS_D[("deploy-redis\nRedis 7\nport 6379")]
        DDASH["deploy-dashboard\ngunicorn port 8080"]
    end

    subgraph ALAYA_DOCKER_MAGI ["Docker: magi project"]
        LITELLM["magi-litellm\nLiteLLM proxy\nport 4000"]
        REDIS_M[("magi-redis\nRedis 7\nlocalhost:6379")]
    end

    subgraph EXTERNAL ["External"]
        BINANCE["Binance\nWebSocket + REST"]
        ANTHROPIC["Anthropic API"]
        XAI["xAI Grok API"]
        TG["Telegram API"]
        PORTAINER["Portainer\nport 9000"]
    end

    subgraph GITHUB ["GitHub (M116cj)"]
        J13OPS["j13-ops\nops hub + specs"]
        QBEYER["qbeyer-models"]
        ZANGETSU_REPO["zangetsu\n[private? unknown]"]
    end

    subgraph NOT_IMPLEMENTED ["Not Implemented (P1-P8 specs)"]
        KING["king-crimson\nHFT executor"]
        SIGNAL_ROUTER["signal-router\nP5"]
        AMADEUS["amadeus\nPolymarket"]
        RSTEINER["r-steiner\nX publisher"]
    end

    %% Data flows
    BINANCE -->|"1m klines OHLCV"| TRADER
    TRADER -->|"READ regime+champions"| PG
    TRADER -->|"WRITE execution_log"| PG
    MLCORE -->|"WRITE pool_champions\npool_features"| PG
    MLCORE -->|"READ klines"| PG
    DDASH -->|"READ PnL, signals"| PG

    ALAYABOT -->|"calls"| QWEN
    QUEUE -->|"job dispatch"| QWEN
    AGENT -.->|"[stopped] calls"| QWEN

    LITELLM -->|"proxy"| ANTHROPIC
    LITELLM <-->|"session cache"| REDIS_M

    ALAYABOT <-->|"poll/send"| TG
    GROKBOT <-->|"poll/send"| TG
    GROKBOT -->|"calls"| XAI

    TRADER -.->|"github_sync [NO TOKEN]"| ZANGETSU_REPO

    %% Planned (not yet wired)
    TRADER -.->|"planned: signal→Redis"| KING
    TRADER -.->|"planned: P5 router"| SIGNAL_ROUTER
    SIGNAL_ROUTER -.->|"planned: post"| RSTEINER
    SIGNAL_ROUTER -.->|"planned: push"| TG
