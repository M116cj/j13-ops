[Unit]
Description=Zangetsu V5 Dashboard API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=j13
WorkingDirectory=/home/j13/j13-ops
EnvironmentFile=/etc/zangetsu/zangetsu.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/j13/j13-ops/zangetsu_v5/.venv/bin/uvicorn zangetsu_v5.dashboard.run:app --app-dir /home/j13/j13-ops --host 0.0.0.0 --port 9901
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
