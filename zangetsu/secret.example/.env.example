# ============================================================
# Zangetsu — secret/.env template
# ============================================================
# Copy this file to ../secret/.env and fill in real values.
# Never commit secret/ — it is gitignored by design.
#
# Permissions after fill:
#   chmod 700 ../secret
#   chmod 600 ../secret/.env
# ============================================================

# Postgres DB (Zangetsu V5 runtime)
ZV5_DB_HOST=<HOST>
ZV5_DB_PORT=<PORT>
ZV5_DB_NAME=<DBNAME>
ZV5_DB_USER=<USERNAME>
ZV5_DB_PASSWORD=<RANDOM_32_CHAR_HEX>

# Add future keys here in the form KEY=<PLACEHOLDER>. Do NOT commit real values.
