      "options": {"alertInstanceLabelFilter": "", "alertName": "", "dashboardAlerts": false, "groupBy": ["alertname", "severity"], "groupMode": "default", "maxItems": 50, "sortOrder": 1, "stateFilter": {"error": true, "firing": true, "noData": false, "normal": false, "pending": true}}
    },
    {
      "type": "timeseries",
      "title": "Redis nexus-redis Connected Clients",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 12},
      "id": 2,
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "redis_connected_clients", "legendFormat": "clients"}]
    },
    {
      "type": "timeseries",
      "title": "Postgres pg_up",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 12},
      "id": 3,
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "pg_up", "legendFormat": "pg_up"}],
      "fieldConfig": {"defaults": {"max": 1, "min": 0}}
