{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0}}
    },
    {
      "type": "timeseries",
      "title": "Memory Usage %",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
        "legendFormat": "RAM %"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0}}
    },
    {
      "type": "timeseries",
      "title": "Disk Available (root)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "node_filesystem_avail_bytes{mountpoint=\"\"}",
        "legendFormat": "Available"
      }],
      "fieldConfig": {"defaults": {"unit": "decbytes"}}
    },
    {
      "type": "timeseries",
      "title": "Network I/O",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(node_network_receive_bytes_total{device=\"eth0\"}[5m])",
          "legendFormat": "RX"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(node_network_transmit_bytes_total{device=\"eth0\"}[5m])",
          "legendFormat": "TX"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "stat",
      "title": "nexus Pipeline Total",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
      "id": 5,
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(nexus_tasks_total)",
        "legendFormat": "Total tasks"
      }]
    },
    {
      "type": "stat",
      "title": "nexus Pipeline In-flight",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 16},
      "id": 6,
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "nexus_pipeline_in_flight",
        "legendFormat": "In-flight"
      }]
    },
    {
      "type": "stat",
      "title": "GPU Temp",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
      "id": 7,
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "gpu_temperature_celsius",
        "legendFormat": "°C"
      }],
      "fieldConfig": {"defaults": {"unit": "celsius"}}
    },
    {
      "type": "stat",
      "title": "GPU VRAM Used",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16},
      "id": 8,
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "gpu_memory_used_mib",
        "legendFormat": "MiB"
      }],
      "fieldConfig": {"defaults": {"unit": "mebibytes"}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["alaya"],
  "templating": {"list": [{"name": "DS_PROMETHEUS", "type": "datasource", "pluginId": "prometheus", "current": {}, "hide": 2}]},
  "time": {"from": "now-1h", "to": "now"},
  "title": "Alaya Overview",
  "uid": "alaya-overview",
  "version": 1
}
