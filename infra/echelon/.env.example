# PostgreSQL connection string (internal Docker network: postgres:5432)
POOL_DATABASE_URL=postgresql://zangetsu:<password>@postgres:5432/zangetsu

# Telegram bot token (@Alaya13jbot)
ALAYA_BOT_TOKEN=

# Telegram group chat ID (negative number)
GROUP_CHAT_ID=

# Telegram thread/topic ID for signal notifications (default: 12)
TOPIC_SIGNALS=12

# Poll interval in seconds (default: 15)
POLL_INTERVAL_S=15

# Minimum signal confidence to forward 0.0–1.0 (default: 0.0 = all)
MIN_CONFIDENCE=0.0
